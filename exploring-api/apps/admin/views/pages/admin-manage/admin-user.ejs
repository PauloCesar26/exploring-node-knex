<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin</title>
  <link href="/admin/static/output.css" rel="stylesheet">
</head>
<body class="bg-zinc-950 text-zinc-100">
  <div class="min-h-screen flex flex-col">
    <div class="flex flex-1">
      <%- include("../../includes/sidebar.ejs"); %>
  
      <main class="flex-1 p-6 lg:p-8 bg-zinc-200">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
          <div>
            <h1 class="text-2xl font-bold text-black">Posts cadastrados</h1>
            <p class="text-sm text-zinc-800">Gerencie os cards do sistema</p>
          </div>

          <a href="/admin/export-data">
            <button class="h-10 px-4 rounded-lg bg-zinc-600 text-white font-medium
                           hover:bg-zinc-500 transition shadow">
              Exportar dados
            </button>
          </a>
        </div>

        <% if(user && user.length > 0) { %>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            <% user.forEach(users => { %>
              <div class="bg-zinc-950 border border-white/10 rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition">
                <form action="/admin/manage-user/<%= users.id %>" method="POST" class="flex flex-col h-full">
                  <div class="w-full h-40 bg-zinc-800 overflow-hidden">
                    <img 
                      src="<%= users.userImg %>" 
                      class="w-full h-full object-cover"
                    >
                  </div>

                  <div class="flex-1 p-4">
                    <p class="text-white font-medium truncate"><%= users.nome %></p>
                    <p class="text-sm text-zinc-400 truncate"><%= users.email %></p>
                  </div>

                  <div class="p-4 pt-0 flex justify-end">
                    <button 
                      class="h-10 px-4 rounded-lg bg-red-600 text-white text-sm font-medium
                             hover:bg-red-500 transition shadow"
                    >
                      Delete
                    </button>
                  </div>
                </form>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="text-center py-10 border border-white/10 rounded-2xl bg-zinc-950">
            <p class="text-zinc-400">Nenhum post encontrado</p>
          </div>
        <% } %>
      </main>
    </div>
  
    <%- include("../../includes/footer.ejs"); %>
  </div>

  <script src="/admin/static/js/sidebar.js"></script>
</body>
</html>