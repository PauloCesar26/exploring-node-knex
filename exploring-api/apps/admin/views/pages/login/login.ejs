<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="/admin/static/output.css" rel="stylesheet">
  <title>Admin</title>
</head>
<body class="min-h-screen bg-zinc-950 flex items-center justify-center p-4 text-zinc-100">
  <div class="w-full max-w-md">
    <div class="p-8 rounded-2xl bg-zinc-900 border border-white/10 shadow-2xl shadow-black/30">
      <header class="text-center mb-6">
        <h1 class="text-2xl font-bold text-white">Login Admin</h1>
        <p class="text-sm text-zinc-400 mt-1">Acesse o painel administrativo</p>
      </header>

      <form action="/admin/login" method="POST" class="flex flex-col gap-5">
        <div class="flex flex-col gap-1">
          <label class="text-sm text-zinc-400">Usuário</label>
          <input 
            type="text" 
            name="user"
            class="w-full h-11 px-3 rounded-lg bg-zinc-950 border border-white/10 text-white
                   focus:outline-none focus:ring-2 focus:ring-white/20 focus:border-white/20 transition"
            required
          >
          <% if(errorUser){ %>
            <p class="text-sm text-red-400 mt-1"><%= errorUser %></p>
          <% } %>
        </div>

        <div class="flex flex-col gap-1">
          <label class="text-sm text-zinc-400">Senha</label>
          <input 
            type="password" 
            name="password"
            class="w-full h-11 px-3 rounded-lg bg-zinc-950 border border-white/10 text-white
                   focus:outline-none focus:ring-2 focus:ring-white/20 focus:border-white/20 transition"
            required
          >
          <% if(errorPassword){ %>
            <p class="text-sm text-red-400 mt-1"><%= errorPassword %></p>
          <% } %>
        </div>

        <button 
          type="submit"
          class="mt-2 h-11 rounded-lg bg-white text-black font-medium hover:bg-zinc-200 transition shadow-lg hover:shadow-xl">
          Entrar
        </button>
      </form>
    </div>

    <p class="text-center text-xs text-zinc-500 mt-6">
      Painel administrativo
    </p>
  </div>
</body>
</html>